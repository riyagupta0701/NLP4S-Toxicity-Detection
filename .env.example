# Copy to .env and fill in. .env is gitignored.

# Cohere — used for Aya (classification + synthetic data generation)
COHERE_API_KEY=

# OpenAI-compatible endpoints for the other open-weight LLMs (Mistral-7B, Llama-3-8B).
# Default: a local server (vLLM / Ollama / llama.cpp / LM Studio). For Ollama
# use http://localhost:11434/v1; for vLLM use http://localhost:8000/v1.
# OPENAI_COMPATIBLE_API_KEY can be any non-empty placeholder for local servers
# (the openai SDK requires the field, local servers ignore it).
OPENAI_COMPATIBLE_API_KEY=local
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1

# Judge model for the LLM-as-judge cell in evaluation.ipynb (Section 4.2).
#
# Local (Ollama):  keep OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
#                  and set LLM_JUDGE_MODEL to whichever model you have pulled
#                  (e.g. llama3, mistral).
#
# Cohere / Colab:  set OPENAI_COMPATIBLE_BASE_URL=https://api.cohere.ai/compatibility/v1
#                  set OPENAI_COMPATIBLE_API_KEY to your COHERE_API_KEY value
#                  set LLM_JUDGE_MODEL=command-r-08-2024
#                  (Trial key: 20 calls/min — the cell throttles automatically.)
LLM_JUDGE_MODEL=llama3
