# Copy to .env and fill in. .env is gitignored.

# Cohere — used for Aya (classification + synthetic data generation)
COHERE_API_KEY=

# OpenAI-compatible endpoints for the other open-weight LLMs (Mistral-7B, Llama-3-8B).
# Point these at whichever hosted provider you use (Mistral API, Together, Groq, etc.).
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
